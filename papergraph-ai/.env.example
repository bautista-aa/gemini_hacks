GEMINI_API_KEY=
# Gemini 3 Flash only (default gemini-3-flash-preview). Optional comma-separated fallbacks, same family.
# GEMINI_MODEL=gemini-3-flash-preview
# GEMINI_MODEL_FALLBACKS=gemini-3-flash,gemini-3.0-flash-preview
# Set to 1 only if your model supports thinkingConfig (otherwise extract may 400).
# GEMINI_THINKING=0
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# URL of the FastAPI backend (no trailing slash)
BACKEND_URL=http://localhost:8000
