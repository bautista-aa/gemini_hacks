GEMINI_API_KEY=
# Optional: override model (default gemini-2.0-flash). Invalid names auto-fallback.
# GEMINI_MODEL=gemini-2.0-flash
# Set to 1 only if your model supports thinkingConfig (otherwise extract may 400).
# GEMINI_THINKING=0
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
# URL of the FastAPI backend (no trailing slash)
BACKEND_URL=http://localhost:8000
